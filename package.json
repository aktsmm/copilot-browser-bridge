{
  "name": "copilot-browser-bridge-chrome",
  "description": "Chrome extension for GitHub Copilot Browser Bridge",
  "private": true,
  "version": "0.1.17",
  "type": "module",
  "scripts": {
    "dev": "wxt",
    "dev:firefox": "wxt -b firefox",
    "lint": "eslint entrypoints wxt.config.ts",
    "test": "vitest run",
    "typecheck": "wxt prepare && tsc -p ./tsconfig.typecheck.json",
    "build": "wxt build",
    "build:firefox": "wxt build -b firefox",
    "zip": "wxt zip",
    "zip:firefox": "wxt zip -b firefox",
    "validate:bridge": "node ./scripts/validate-bridge-consistency.mjs",
    "cws:setup": "pwsh -ExecutionPolicy Bypass -File ./scripts/setup-cws-credentials.ps1 -OpenBrowser",
    "postinstall": "wxt prepare"
  },
  "devDependencies": {
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@wxt-dev/module-react": "^1.1.5",
    "@typescript-eslint/eslint-plugin": "^8.31.1",
    "@typescript-eslint/parser": "^8.31.1",
    "autoprefixer": "^10.4.20",
    "eslint": "^9.26.0",
    "postcss": "^8.4.49",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "sharp": "^0.34.5",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.7.0",
    "vitest": "^3.2.4",
    "wxt": "^0.19.0"
  },
  "dependencies": {
    "react-markdown": "^10.1.0",
    "rehype-sanitize": "^6.0.0",
    "remark-gfm": "^4.0.1"
  }
}
